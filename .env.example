# -----------------------------------------------------------------------------
# AgriScan+ Environment Template
# Copy this file to .env and replace placeholder values.
# -----------------------------------------------------------------------------

# Django core
DJANGO_SETTINGS_MODULE=mysite.settings
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
APP_BASE_URL=http://127.0.0.1:8000

# MySQL database
DB_ENGINE=django.db.backends.mysql
DB_NAME=agriscan_db
DB_USER=root
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306

# Email / SMTP (Gmail App Password recommended)
# Note: In-app System Settings can override email toggle via DB (email_enabled).
# EMAIL_ENABLED is used as fallback when SiteSetting is missing/unavailable.
EMAIL_ENABLED=False
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
DEFAULT_FROM_EMAIL=AgriScan+ <noreply@example.com>

# Yield CNN runtime settings
# Note: System Settings can override user-facing CNN toggle via DB (yield_cnn_enabled).
# YIELD_CNN_ENABLED is used as fallback when SiteSetting is missing/unavailable.
YIELD_CNN_ENABLED=False
YIELD_CNN_CHECKPOINT_PATH=models/rice_yield_CNN.pth
YIELD_CNN_DEVICE=cpu

# Optional app settings
TIME_ZONE=Asia/Manila
LANGUAGE_CODE=en-us
